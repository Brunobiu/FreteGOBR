# Supabase Configuration
# Get these values from your Supabase project settings:
# 1. Go to https://supabase.com/dashboard
# 2. Create a new project or select existing project
# 3. Go to Settings > API
# 4. Copy the values below:

# Project URL (e.g., https://xxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url

# Anon/Public Key (safe to use in frontend)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (NEVER expose in frontend - use only in backend/migrations)
VITE_SUPABASE_SERVICE_KEY=your_supabase_service_key

# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# Map Configuration (Optional - for geocoding services)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# =====================================================
# Marketing — Meta Pixel (site publico)
# =====================================================

# Pixel ID PUBLICO do Meta Pixel usado pelo Pixel_Loader no site publico.
# Valor NAO-SENSIVEL (ja embute no JS entregue ao navegador). Somente digitos.
# Sem este valor o Pixel simplesmente nao e carregado. O Access Token da Meta
# NUNCA fica aqui: ele vive somente no Supabase Vault, lido server-side.
VITE_META_PIXEL_ID=your_meta_pixel_id

# =====================================================
# Admin Panel (admin-foundation)
# =====================================================

# Chave de cifragem AES-256-GCM do segredo TOTP do MFA admin.
# Gere com: openssl rand -base64 32
# NUNCA comite o valor real. Rotacao documentada em
# .kiro/specs/admin-foundation/RECOVERY.md
VITE_ADMIN_MFA_KEY=your_admin_mfa_key_base64
